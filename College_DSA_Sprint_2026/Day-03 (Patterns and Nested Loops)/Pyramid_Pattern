#include <iostream>
using namespace std;

int main()
{
    int n;
    cin >> n;

    // code here
    for (int i = 1; i <= n; i++)
    {
        for (int j = i; j < n; j++)
        {
            cout << " ";
        }
        for (int j = 1; j <= (2 * i - 1); j++)
        {
            cout << "*";
        }
        cout << "\n";
    }
    return 0;
}