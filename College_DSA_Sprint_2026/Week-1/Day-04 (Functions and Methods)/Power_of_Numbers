#include <bits/stdc++.h>
using namespace std;
class Solution
{
public:
    int reverseExponentiation(int n)
    {
        // code here
        int rev = 0;
        int temp = n;
        while (temp > 0)
        {
            rev = rev * 10 + (temp % 10);
            temp /= 10;
        }
        long long res = 1;
        for (int i = 0; i < rev; i++)
        {
            res = res * n;
        }
        return res;
    }
};