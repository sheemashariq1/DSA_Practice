#include <bits/stdc++.h>
using namespace std;

class Solution
{
public:
    vector<int> singleNum(vector<int> &arr)
    {
        // Code here.
        sort(arr.begin(), arr.end());
        vector<int> res;
        for (int i = 0; i < arr.size(); i++)
        {
            if (i == arr.size() - 1 || arr[i] != arr[i + 1])
            {
                res.push_back(arr[i]);
            }
            else
            {
                i++;
            }
        }
        return res;
    }
};