// Given a string s in Roman number format, your task is to convert it to an integer. Various symbols and their values are given below.
// Note: I = 1, V = 5, X = 10, L = 50, C = 100, D = 500, M = 1000

#include <bits/stdc++.h>
using namespace std;

class Solution
{
public:
    int romanToDecimal(string &s)
    {
        // code here
        int roman[128] = {0};
        roman['I'] = 1;
        roman['V'] = 5;
        roman['X'] = 10;
        roman['L'] = 50;
        roman['C'] = 100;
        roman['D'] = 500;
        roman['M'] = 1000;
        int total = 0;
        int n = s.length();
        for (int i = 0; i < n; i++)
        {
            if (i + 1 < n && roman[s[i]] < roman[s[i + 1]])
            {
                total -= roman[s[i]];
            }
            else
            {
                total += roman[s[i]];
            }
        }
        return total;
    }
};