// Given a sorted array arr[] and an integer k,find the position(0-based indexing) at which k is present in the array using binary search.
// If k doesn't exist in arr[] return -1.

#include <bits/stdc++.h>
using namespace std;

class Solution
{
public:
    int firstSearch(vector<int> &arr, int k)
    {
        // code here
        int low = 0;
        int res = -1;
        int high = arr.size() - 1;
        while (low <= high)
        {
            int mid = low + (high - low) / 2;
            if (arr[mid] == k)
            {
                res = mid;
                high = mid - 1;
            }
            else if (arr[mid] < k)
            {
                low = mid + 1;
            }
            else
            {
                high = mid - 1;
            }
        }
        return res;
    }
};