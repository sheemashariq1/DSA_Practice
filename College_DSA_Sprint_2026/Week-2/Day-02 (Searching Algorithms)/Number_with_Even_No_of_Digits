// Given an array nums of integers, return how many of them contain an even number of digits.

#include <bits/stdc++.h>
using namespace std;

class Solution
{
public:
    int findNumbers(vector<int> &nums)
    {
        int count = 0;
        for (int n : nums)
        {
            int digit = 0;
            while (n > 0)
            {
                digit++;
                n /= 10;
            }
            if (digit % 2 == 0)
            {
                count++;
            }
        }
        return count;
    }
};
