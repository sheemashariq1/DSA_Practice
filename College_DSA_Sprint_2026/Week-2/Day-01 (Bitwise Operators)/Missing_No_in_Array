#include <bits/stdc++.h>
using namespace std;

class Solution
{
public:
    int missingNum(vector<int> &arr)
    {
        // code here
        int n = arr.size() + 1;
        int sum1 = 0;
        int sum2 = 0;
        for (int i = 1; i <= n; i++)
        {
            sum1 += i;
        }
        for (int i = 0; i < arr.size(); i++)
        {
            sum2 += arr[i];
        }
        return sum1 - sum2;
    }
};