#include <iostream>
#include <vector>
using namespace std;

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    int n;
    if (cin >> n)
    {
        vector<int> arr(n);
        for (int i = 0; i < n; i++)
        {
            cin >> arr[i];
        }
        // Write your code here to find the single element
        int res = 0;
        for (int n : arr)
        {
            res ^= n;
        }
        cout << res;
    }
    return 0;
}