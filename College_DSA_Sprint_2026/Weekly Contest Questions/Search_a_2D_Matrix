#include <iostream>
#include <vector>
using namespace std;

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    int m, n, target;
    if (cin >> m >> n >> target)
    {
        vector<vector<int>> matrix(m, vector<int>(n));
        for (int i = 0; i < m; i++)
        {
            for (int j = 0; j < n; j++)
            {
                cin >> matrix[i][j];
            }
        }
        // Write your code here
        int low = 0;
        int high = (m * n) - 1;
        bool found = false;
        while (low <= high)
        {
            int mid = low + (high - low) / 2;
            int r = mid / n;
            int c = mid % n;
            if (matrix[r][c] == target)
            {
                found = true;
                break;
            }
            else if (matrix[r][c] < target)
            {
                low = mid + 1;
            }
            else
            {
                high = mid - 1;
            }
        }
        if (found)
        {
            cout << "true";
        }
        else
        {
            cout << "false";
        }
    }
    return 0;
}