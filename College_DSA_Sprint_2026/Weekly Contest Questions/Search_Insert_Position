#include <iostream>
#include <vector>
using namespace std;

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    int n, target;
    if (cin >> n >> target)
    {
        vector<int> arr(n);
        for (int i = 0; i < n; i++)
        {
            cin >> arr[i];
        }
        // Write your code here to find insert position of target
        int insert_index = n;
        for (int i = 0; i < arr.size(); i++)
        {
            if (arr[i] >= target)
            {
                insert_index = i;
                break;
            }
        }
        cout << insert_index << "\n";
    }
    return 0;
}