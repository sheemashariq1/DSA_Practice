#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    int n, k;
    if (cin >> n >> k)
    {
        vector<int> arr(n);
        for (int i = 0; i < n; i++)
        {
            cin >> arr[i];
        }
        // Write your code here to find the maximum possible minimum distance
        sort(arr.begin(), arr.end());
        int low = 1;
        int high = arr[n - 1] - arr[0];
        int result = 0;
        while (low <= high)
        {
            int mid = low + (high - low) / 2;
            int cow = 1;
            int pos = arr[0];
            for (int i = 1; i < n; i++)
            {
                if (arr[i] - pos >= mid)
                {
                    cow++;
                    pos = arr[i];
                }
            }
            if (cow >= k)
            {
                result = mid;
                low = mid + 1;
            }
            else
            {
                high = mid - 1;
            }
        }
        cout << result;
    }
    return 0;
}