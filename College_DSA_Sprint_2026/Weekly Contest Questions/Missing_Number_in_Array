#include <iostream>
#include <vector>
using namespace std;

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    int n;
    int sum1 = 0;
    if (cin >> n)
    {
        vector<int> arr(n);
        for (int i = 0; i < n; i++)
        {
            cin >> arr[i];
        }
        // Write your code here
        for (int i = 1; i <= n + 1; i++)
        {
            sum1 += i;
        }
        int sum2 = 0;
        for (int i = 0; i < n; i++)
        {
            sum2 += arr[i];
        }
        cout << sum1 - sum2 << "\n";
    }
    return 0;
}