#include <iostream>
#include <vector>
using namespace std;

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    int n;
    if (cin >> n)
    {
        vector<int> arr(n);
        for (int i = 0; i < n; i++)
        {
            cin >> arr[i];
        }
        vector<int> result(n);
        // Write your code here
        int positive = 0;
        int negative = 1;
        for (int i = 0; i < n; i++)
        {
            if (arr[i] > 0)
            {
                result[positive] = arr[i];
                positive += 2;
            }
            else
            {
                result[negative] = arr[i];
                negative += 2;
            }
        }
        for (int i = 0; i < n; i++)
        {
            cout << result[i] << " ";
        }
    }
    return 0;
}