#include <iostream>
#include <string>
using namespace std;

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    string s;
    if (cin >> s)
    {
        // Write your code here
        int read = 0;
        int write = 0;
        int n = s.length();

        while (read < n)
        {
            char current = s[read];
            int count = 0;
            while (read < n && s[read] == current)
            {
                read++;
                count++;
            }
            s[write++] = current;
            if (count > 1)
            {
                std::string count_str = std::to_string(count);
                for (char digit : count_str)
                {
                    s[write++] = digit;
                }
            }
        }
        cout << s.substr(0, write);
    }
    return 0;
}