#include <iostream>
#include <vector>
#include <climits>
using namespace std;
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int n;
    if (cin >> n)
    {
        if (n <= 0)
            return 0;

        vector<int> arr(n);
        for (int i = 0; i < n; i++)
        {
            cin >> arr[i];
        }
        int current_max = INT_MIN;
        vector<int> result;
        for (int i = n - 1; i >= 0; i--)
        {
            if (arr[i] >= current_max)
            {
                current_max = arr[i];
                result.push_back(arr[i]);
            }
        }
        for (size_t i = result.size(); i > 0; i--)
        {
            cout << result[i - 1] << " ";
        }
        cout << "\n";
    }
    return 0;