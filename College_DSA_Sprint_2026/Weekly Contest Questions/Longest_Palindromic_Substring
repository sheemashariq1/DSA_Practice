#include <iostream>
#include <string>
using namespace std;

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    string s;
    if (cin >> s)
    {
        // Write your code here
        int n = s.length();
        int start = 0, len = 1;
        for (int i = 0; i < n; i++)
        {
            for (int j = 0; j <= 1; j++)
            {
                int left = i;
                int right = i + j;
                while (left >= 0 && right < n && s[left] == s[right])
                {
                    int current = right - left + 1;
                    if (current > len)
                    {
                        start = left;
                        len = current;
                    }
                    left--;
                    right++;
                }
            }
        }
        cout << s.substr(start, len) << "\n";
    }
    return 0;
}