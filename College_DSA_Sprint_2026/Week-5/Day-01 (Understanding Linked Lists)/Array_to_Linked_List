// You are given an array arr[] of integers.
// You have to construct a singly linked list  from the elements of the arr[] and return the head of the linked list.

#include <bits/stdc++.h>
using namespace std;

/*
// Representation of a node
class Node {
public:
    int data;
    Node* next;

    Node(int d) {
        data = d;
        next = NULL;
    }
};
*/

class Solution
{
public:
    Node *arrayToList(vector<int> &arr)
    {
        // code here
        Node *head = new Node(arr[0]);
        Node *mover = head;
        for (int i = 1; i < arr.size(); i++)
        {
            Node *temp = new Node(arr[i]);
            mover->next = temp;
            mover = temp;
        }
        return head;
    }
};