#include <bits/stdc++.h>
using namespace std;

class Solution
{
public:
    int getSecondLargest(vector<int> &arr)
    {
        // code here
        int max = 0;
        int second_max = -1;
        for (int i = 0; i < arr.size(); i++)
        {
            if (arr[i] > max)
            {
                max = arr[i];
            }
        }
        for (int i = 0; i < arr.size(); i++)
        {
            if (arr[i] > second_max && arr[i] < max)
            {
                second_max = arr[i];
            }
        }
        return second_max;
    }
};