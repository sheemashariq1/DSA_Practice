#include <bits/stdc++.h>
using namespace std;
class Solution
{
public:
    bool armstrongNumber(int n)
    {
        // code here
        int org = n;
        int sum = 0;
        int digit;
        while (n > 0)
        {
            digit = n % 10;
            sum += (digit * digit * digit);
            n /= 10;
        }
        return sum == org;
    }
};