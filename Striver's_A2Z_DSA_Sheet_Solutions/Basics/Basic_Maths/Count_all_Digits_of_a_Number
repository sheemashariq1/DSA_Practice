// You are given an integer n. You need to return the number of digits in the number.
// The number will have no leading zeroes, except when the number is 0 itself.

#include <bits/stdc++.h>
using namespace std;

class Solution
{
public:
    int countDigit(int n)
    {
        int digit = 0;
        while (n > 0)
        {
            digit++;
            n /= 10;
        }
        return digit;
    }
};